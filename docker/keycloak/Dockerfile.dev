FROM quay.io/keycloak/keycloak:latest

# Bake the ToTen realm so Keycloak imports it on first start.
# Uses start-dev (H2 embedded DB) — no Postgres dependency for local development.
# Build context must be the repo root: docker build -f docker/keycloak/Dockerfile.dev -t toten-keycloak-dev:local .
COPY src/ToTen.AppHost/realms/ToTen-realm.json /opt/keycloak/data/import/ToTen-realm.json

ENTRYPOINT ["/opt/keycloak/bin/kc.sh"]
CMD ["start-dev", "--import-realm"]
